<!-- start Simple Custom CSS and JS -->
<script>
let images = document.querySelectorAll('img');
images.forEach(img => {
    // Cambiar el src principal de http a https
    if (img.src.startsWith('http://')) {
        img.src = img.src.replace('http://', 'https://');
    }
    
    // Cambiar los srcset de http a https (si existen)
    if (img.srcset) {
        let updatedSrcset = img.srcset.replace(/http:\/\//g, 'https://');
        img.srcset = updatedSrcset;
    }
});</script>
<!-- end Simple Custom CSS and JS -->
<script>
window.addEventListener("scroll", function () {
  var scrollPosition = window.scrollY;
  var body = document.body;
  var scrollThreshold = 50;
 
  if (scrollPosition > scrollThreshold) {
    body.classList.add("header__fixed");
  } else {
    body.classList.remove("header__fixed");
  }
});
