		<style id="wp-custom-css">
			.mb-0, .mb-0 p {
	margin-bottom: 0px !important;
}

.IconList ul li {
	width: 90%;
	gap: 10px;
	text-align:cen
}

.IconList ul li svg {
	width: 40px !important;
	height: 40px !important;
}

.IconList ul li .elementor-icon-list-icon {
	width: 40px !important;
	height: 40px !important;
	display: block !important;
}

.IconList ul li .elementor-icon-list-text {
	width: 80%;
}

.IconList ul {
	row-gap: 50px;
}

.Xray_Slider .elementor-swiper-button-next {
	right: auto !important;
	left: 70px !important;
}

.ClientsSlider .swiper-slide .elementor-testimonial .elementor-testimonial__content {
	padding-top: 20px;
/* 	border-top: 2px solid #5A5D77; */
	margin-top: 40px;
	position: relative;
}

.ClientsSlider .swiper-slide .elementor-testimonial .elementor-testimonial__content::before {
	content: '';
	position: absolute;
	background: url(https://hdxwill.de/wp-content/uploads/2025/01/Group-97.svg) no-repeat;
	background-size: contain;
	width: 120px;
	height: 120px;
	left: 0;
	top: -60px;
	z-index: 99;
}
@media(max-width: 767px){
	.ClientsSlider .swiper-slide .elementor-testimonial .elementor-testimonial__content::before{
		width: 100px;
		height: 100px;
	}
}

.ClientsSlider .swiper-pagination {
	justify-content: center !important;
	padding-left: 30px !important;
	bottom: 60px !important;
}

.ClientsSlider .swiper-pagination .swiper-pagination-bullet {
	width: 5px;
	height: 5px;
	background-color: transparent;
/* 	border: 1px solid #2F476F; */
}

.ClientsSlider .swiper-pagination .swiper-pagination-bullet.swiper-pagination-bullet-active {
	background: #22c55e;
	width: 20px;
}

.ClientsSlider .elementor-swiper-button {
	border: 1px solid #fff;
	box-shadow: 0px 0px 6px #0052d657;
	width: 40px;
	height: 40px;
	border-radius: 50px;
	display: flex;
	justify-content: center;
	align-items: center;
}

.ClientsSlider .elementor-swiper-button svg {
	color: #404361;
	fill: #404361 !important;
	width: 15px !important;
	height: 15px !important;
}

.ClientsSlider .elementor-swiper-button.elementor-swiper-button-next {
	bottom: auto;
	top: 50px !important;
	top: auto;
	right: 40px;
}

.ClientsSlider .elementor-swiper-button.elementor-swiper-button-prev {
	bottom: auto;
	top: 50px;
	left: auto;
	right: 90px;
}

.image-container {
	position: relative;
	height: 360px;
	overflow: hidden;
}

.image {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: clip-path 0.3s ease, filter 0.3s ease;
}

.before {
	clip-path: inset(0 0 0 0);
	z-index: 1;
}

.after {
	clip-path: inset(0 100% 0 0);
	z-index: 2;
}

.slider {
	position: absolute;
	top: 0;
	left: 50%;
	transform: translateX(-50%);
	width: 3px;
	height: 100%;
	background: #fff;
	cursor: pointer;
	z-index: 3;
}

.BannerImageButton {
	left: -80px !important;
}

.BannerImageButton a {
	white-space: nowrap;
	pointer-events: none;
}


.Home_Banner {
	position: relative;
	max-width: 800px;
	margin: 0 auto;
}

.Home_Banner .sr7-thumb.sr7-thumb {
	height: fit-content !important;
	padding: 14px 20px !important;
	width: fit-content !important;
	display: inline-block;
	border-radius: 8px !important;
	overflow: hidden;
	background: #43608F !important;
	color: #fff !important;
	transform: translate(0px, 0px) !important;
	position: static !important;
}

.Home_Banner .sr7-thumb.sr7-thumb.selected .sr7-thumb-over {
	background: #2F476F !important;
}


.Home_Banner .sr7-ntiw .sr7-thumb.selected .sr7-thumb-title {
	color: #fff !important;
}

.Home_Banner .sr7-thumb-more {
	display: none !important;
}

.Home_Banner .sr7-ntiw .sr7-thumb-title {
	position: relative !important;
	display: inline-block !important;
	width: fit-content !important;
	padding: 0px !important;
	font-family: Manrope !important;
	font-size: 14px !important;
	white-space: nowrap !important;
	font-weight: 700 !important;
	line-height: 21.86px !important;
}

.Home_Banner .sr7-ntiw .sr7-thumb[data-key="1"] .sr7-thumb-title::before {
	content: 'AI MAR';
	display: inline-block;
}

.Home_Banner .sr7-ntiw .sr7-thumb[data-key="4"] .sr7-thumb-title::before {
	content: 'Panorama Auto Focus';
	display: inline-block;
}

.Home_Banner .sr7-ntiw .sr7-thumb[data-key="5"] .sr7-thumb-title::before {
	content: 'Auto landmark detection';
	display: inline-block;
}

.Home_Banner .sr7-thumbs-mask .sr7-ntiw {
	display: flex;
	justify-content: space-between;
	gap: 20px;
}

.PdpTabs .elementor-swiper-button {
	border: 1px solid;
	border-radius: 50px;
	padding: 4px;
	bottom: -80px;
	top: auto !important;
	left: 0;
	right: 0;
	margin: 0 auto !important;
	width: fit-content;
}

.PdpTabs .elementor-swiper-button.elementor-swiper-button-next {
	right: -60px !important;
}

.PdpTabs .elementor-swiper-button.elementor-swiper-button-prev {
	left: -60px !important;
}

.PdpTabs .swiper-slide-inner img {
	padding: 50px;
	border-radius: 20px;
	background: #F7F7FD;
}

.PdpTabs .EcoList ul li, .Full_List ul li {
	width: 100% !important;
}

.PdpTabs .IconList ul {
	row-gap: 30px;
}

.BottomTabs .swiper-slide-contents {
	width: 100% !important;
}

.BottomTabs .swiper-slide-inner img {
	padding: 0px;
	border-radius: 0px;
	background: transparent;
}


.PdpTabs .elementor-swiper-button.elementor-swiper-button-prev {
	left: auto !important;
	right: 70px !important;
	bottom: auto;
	top: 40px !important;
}


.PdpTabs .elementor-swiper-button.elementor-swiper-button-next {
	left: auto !important;
	right: 20px !important;
	bottom: auto;
	top: 40px !important;
}
@media(max-width:767px){
	.PdpTabs .elementor-swiper-button.elementor-swiper-button-next, .PdpTabs .elementor-swiper-button.elementor-swiper-button-prev{
		top: -30px !important;
	}
}

.PdpTabs .EcoList ul li::marker {
	color: #2CA735;
	font-size: 22px;
}

.HomeTabs .elementor-icon-list--layout-inline ul li{
	width: calc(34% - 20px);
	gap: 10px;
}


.video__section--overlay{
	height: 733px;
}
.video__section--overlay video{
	height: 100%;
}

select {
	background-image: none !important;
}
.elementor-select-wrapper .select-caret-down-wrapper svg{
	fill: #2F476F !important;
}

.BottomTabs .TabsContentSide li {
	font-size: 16px !important;
}

.HomeTabs.PdpTabs.BottomTabs .Tab {
	margin-top: 50px;
}

.BottomTabs.PdpTabs .elementor-swiper-button {
	bottom: -40px;
	height: 30px;
}
.e-con-inner .custom-tabs{
	text-align: center;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 20px;
}
/* .e-con-inner .custom-tabs button{
	background-color: #43608F;
	font-weight: 600;
	border-style: solid;
	border-width: 1px 1px 1px 1px;
	border-color: #43608F;
	border-radius: 8px 8px 8px 8px;
	color: #fff;
	font-size: 15px;
	line-height: 1;
	padding: 12px 24px;;
}
.e-con-inner .custom-tabs button.active{
	background-color: #2F476F;
} */
.e-con-inner .custom-tabs button {
    background-color: transparent;
    font-weight: 600;
    border: 1px solid #D1D1D1;
    border-radius: 7px;
    color: #fff;
    font-size: 14px;
    line-height: 1;
    padding: 12px 24px;
    display: inline-block;
}
.e-con-inner .custom-tabs button.active{
    border-color: #04C13B;
    background-color: #04C13B;
}
.toggle__main{
	width: auto;
	display: block;
}
.gtranslate_wrapper{
	border: 1px solid #2F476F;
	border-radius: 10px;
	padding: 7px;
}
.gt_float_wrapper{
	display: flex !important;
	align-items: center;
}
.gt_float_switcher{
	box-shadow: none !important;
	background: transparent !important;
}
.gt_float_switcher .gt-selected .gt-current-lang{
	padding: 0 !important;
}
.gt_float_switcher img {
	width: 18px !important;
	margin: 0 !important;
}
.gt_float_switcher{
	font-size: 14px !important;
	color: #2F476F !important;
	font-family: var(--bs-body-font-family) !important;
}
.gt_float_wrapper{
	display: flex;
}
.toggle__main #gt_float_wrapper .gt_float_switcher{
	width: 48.73px;
}
.toggle__main .gt-selected .gt-current-lang{
	display: flex;
	align-items: center;
	gap: 2px;
}
.toggle__main .gt-selected .gt_float_switcher-arrow{
	height: 8px;
	width: 8px;
	transform: rotate(0deg);
}
.toggle__main #gt_float_wrapper{
	display: flex;
}
.lang__custom-switch{
	gap: 15px !important;
}
.toggle__main .gtranslate_wrapper .gt_options{
	position: absolute;
	top: 100%;
	left: 0px;
	background: #fff;
	width: 130px;
	box-shadow: 0px 0px 10px #00000038;
}
.our__technologies--col li::marker{
	width: 8px;
	height:8px;
	color:#04C13B;
}
.Xray_Slider .e-n-carousel{
	padding-bottom: 0 !important;
}
.Xray_Slider .swiper-pagination{
	justify-content: start !important;
}
.Xray_Slider .swiper-pagination span{
	width: 11px;
	height: 11px;
	background: #BAC1E5;
}
.Xray_Slider .swiper-pagination span.swiper-pagination-bullet-active{
	width: 11px;
	height: 11px;
	background: #0006A3;
}
.gtranslate_wrapper {
	border: none !important;
	border-radius: 0 !important;
	padding: 0 !important;
}
.gt_float_switcher .gt-selected{
	background-color: transparent !important;
}
.gt_float_switcher .gt-current-lang .gt-lang-code{
	color: #fff !important;
}
.gt_float_switcher .gt-current-lang img{
	width: 14px !important;
	height: 14px !important;
	border-radius: 50% !important;
	object-fit: cover !important;
}
.gt_float_switcher .gt-selected .gt-current-lang span.gt-lang-code {
	top: 0px !important;
	font-size: 12px !important;
}
.toggle__main #gt_float_wrapper .gt_float_switcher {
	width: auto !important;
}
.toggle__main .gt-selected .gt-current-lang {
	gap: 7px;
}
.gt_float_switcher .gt-selected .gt-current-lang span.gt_float_switcher-arrow {
	display: inline-block !important;
	height: 14px !important;
	width: 14px !important;
	vertical-align: middle !important;
	background-image: url(https://hdxwill.de/wp-content/uploads/2025/01/Path-145.svg) !important;
	background-position: 50% !important;
	background-size: 10px !important;
	background-repeat: no-repeat !important;
	transition: all .3s;
	transform: none !important;
}
.lang__custom-switch {
	gap: 45px !important;
}
.lang__custom-switch #gt_float_wrapper{
	position: relative;
}
.lang__custom-switch #gt_float_wrapper::before{
	content: "";
	width: 1px;
	height: 100%;
	background-color: #fff;
	position: absolute;
	top: 0px;
	left: -23px;
}


/* Responsive Css Start */

@media(max-width:1370px){
	.Web_Header ul li a {
		font-size: 14px !important;
		padding: 0px 10px !important;
	}
}

@media(max-width:1230px){
	.Web_Header .elementor-social-icons-wrapper.elementor-grid {
		display: flex;
		gap: 10px;
		justify-content: flex-end;
	}

	.IconList {
		padding-right: 0px;
		width: 50% !important;
	}

	.IconList ul {
		row-gap: 10px;
	}
}

@media(max-width:1070px){
	.Web_Header ul li a {
		font-size: 14px !important;
		padding: 0px 7px !important;
	}

}

@media(max-width:1024px){
	.Web_Header nav.elementor-nav-menu--dropdown.elementor-nav-menu__container a {
		font-size: 20px !important;
		padding: 10px 26px !important;
		line-height: 30px;
	}

	.Web_Header .Navigation .elementor-widget-nav-menu .elementor-menu-toggle, .Navigation  {
		background-color: transparent !important;
	}
	.video__section--overlay {
		height: 380px;
	}	
	.image-container {
		height: 200px;
	}
	.e-con-inner .custom-tabs {
		gap: 10px;
	}
	.e-con-inner .custom-tabs button {
		font-size: 12px;
		padding: 8px 10px;
	}

}

@media(max-width:991px){
	.IconList ul li, .ProductTabs .IconList ul li {
		width: calc(100% - 20px);
	}
	.HomeTabs .elementor-icon-list--layout-inline ul li{
		width: calc(100% - 20px);
	}

	.DownloadButton {
		width: 50%;
		left: auto !important;
		right: 0;
	}

	.HomeTabs .Tab {
		padding: 40px 0px;
		margin-top: 50px;
	}

	.Home_Banner .sr7-thumbs-mask .sr7-ntiw {
		flex-wrap: wrap;
		gap: 10px;
		height: fit-content;
	}

	.Home_Banner .sr7-thumbs-mask, .Home_Banner .sr7-thumbs {
		height: 100% !important;
		display: flex;
		align-items: end;
	}

}
@media(max-width:767px){
	.HomeTabs .Tab {
		padding: 20px 0px;
		margin-top: 20px;
	}
}

.Home_Banner #SR7_1_1 .dione.sr7-arrows.sr7-touchhover {
	background: transparent !important;
}

.Home_Banner #SR7_1_1 .dione.sr7-arrows.sr7-touchhover::before {
	opacity: 1 !important;
}

@media(max-width:767px){
	
.ProductTabs .HomeTabs.PdpTabs.BottomTabs .Tab {
  margin-top: 0px !important;
}
	
.ProductTabs .BottomTabs .Tab .elementor-element.e-con-full .Spacing {
  padding: 14px 0px !important;
}
	
	.Web_Header nav.elementor-nav-menu--dropdown.elementor-nav-menu__container a {
		font-size: 18px !important;
		padding: 6px 22px !important;
		line-height: 26px;
	}

	.IconList {
		padding-right: 0px;
		width: 100% !important;
	}

	.Xray_Slider .elementor-swiper-button-prev,
	.Xray_Slider .elementor-swiper-button-next {
		bottom: -90px;
		top: auto !important;
	}

	.Xray_Slider .elementor-swiper-button-prev {
		left: 0px !important;
	}

	.Xray_Slider .elementor-swiper-button-next {
		left: 50px !important;
	}

	.image-container {
		height: 280px;
	}

	.BottomTabs .Tab {
		padding: 0px !important;
	}

	.BottomTabs .Tab .elementor-element.e-con-full{
		padding: 0px !important;
	}

	.TabsContentSide {
		margin-top: 30px !important;
	}

	.PdpTabs.BottomTabs.elementor-widget-n-tabs .e-n-tabs {
		gap: 40px !important;
	}
	.video__section--overlay {
		height: 230px;
	}
}
.company__image--container-tab .elementor-widget-image{
	overflow: hidden;
}
.technolody__subPages--border-radius .elementor-widget-image{
	overflow: hidden;
}
.Home_Banner .image-container{
	background-color: #000;
	border-radius: 26px;
	overflow: hidden;
}
.technology__card--description p{
	min-height: 82px;
}
.our__technologies--col{
	min-height: 110px;
}
@media(max-width: 767px){
	.technology__card--description p{
	min-height: 100%;
}
.our__technologies--col{
	min-height: 100%;
}
}
.elementor-element-09f5e71{
	min-height: 100%;
}
.elementor-element-09f5e71, .elementor-element-a250882 {
	height: 100%;
}
.products__images--carousel .elementor-swiper-button{
	border-radius: 50%;
	width: 30px;
	height: 30px;
	border: 1px solid #2CA735;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	position: absolute;
	top: 0 !important;
	right: 0 !important;
	left: auto !important;
}
.products__images--carousel .elementor-swiper-button.elementor-swiper-button-prev{
	right: 36px !important;
}
.footer__hidden-heading{
	opacity: 0;
}


.Web_Header{
    position: fixed;
    top: 0px !important;
		width: 100%;
    z-index: 9999;
    -webkit-transition: all 0.3s ease-in-out;
    -moz-transition: all 0.3s ease-in-out;
    -ms-transition: all 0.3s ease-in-out;
    -o-transition: all 0.3s ease-in-out;
    transition: all 0.3s ease-in-out;
}

.header__fixed .Web_Header{
    background-color: #000;
    -webkit-transition: all 0.3s ease-in-out;
    -moz-transition: all 0.3s ease-in-out;
    -ms-transition: all 0.3s ease-in-out;
    -o-transition: all 0.3s ease-in-out;
    transition: all 0.3s ease-in-out;
}
